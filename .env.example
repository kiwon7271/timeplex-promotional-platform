NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 고객 대화 자동 번역 (OpenAI)
# .env.local에 키를 넣으면 매장→고객·고객→매장 번역이 동작합니다.
OPENAI_API_KEY=
# 선택 — 기본값 gpt-4o-mini
OPENAI_TRANSLATION_MODEL=

# 배포 URL (Vercel Webhook·절대 URL용)
# Production: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=

# 통합관리자 최초 생성·비밀번호 설정 (npm run create-admin)
# 8자 이상, 1234 등 단순 비밀번호 불가
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
